# ─────────────────────────────────────────────────────────────────────────────
#  Graph-Based Plagiarism Detection System — Environment Configuration
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Graph Plagiarism Detector"
APP_ENV=development                    # development | staging | production
API_VERSION=v1
DEBUG=true

# ── URLs ──────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/plagiarism_db?sslmode=require

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440       # 24 hours

# ── File Storage ──────────────────────────────────────────────────────────────
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10                    # in megabytes
ALLOWED_EXTENSIONS=pdf,txt,docx

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
